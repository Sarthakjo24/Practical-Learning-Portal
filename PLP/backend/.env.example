PROJECT_NAME=Practical Learning Portal API
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=45

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://plp.api
AUTH0_CLIENT_ID=auth0-client-id
AUTH0_CLIENT_SECRET=auth0-client-secret
AUTH0_ADMIN_ROLE=plp_admin

DB_HOST=localhost
DB_PORT=3306
DB_USER=plp_app
DB_PASSWORD=change-me
DB_NAME=practical_learning_portal

REDIS_URL=redis://localhost:6379/0

STORAGE_PATH=
QUESTION_AUDIO_PATH=
PROMPT_TEMPLATE_PATH=
ALLOWED_AUDIO_EXTENSIONS=.wav,.mp3,.m4a,.webm,.ogg
MAX_AUDIO_UPLOAD_BYTES=15728640
CANDIDATE_QUESTION_COUNT=5
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
API_RATE_LIMIT=100/minute
SQL_ECHO=false

FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=auto
FASTER_WHISPER_COMPUTE_TYPE=int8
